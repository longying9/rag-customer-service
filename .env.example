# ============================================
# RAG 智能客服系统 - 环境变量配置
# 复制此文件为 .env 并填入你的API密钥
# ============================================

# LLM 提供商选择: dashscope 或 openai
LLM_PROVIDER=dashscope

# -------- 阿里云 DashScope (通义千问) --------
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# -------- OpenAI 兼容接口 (可选) --------
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE=https://api.openai.com/v1

# -------- 模型配置 --------
# qwen-plus (推荐，性价比高) / qwen-max (最强) / qwen-turbo (最快)
LLM_MODEL=qwen-plus

# 嵌入模型 (首次运行会自动下载，约120MB)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 文档分块参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 向量数据库存储路径
CHROMA_PERSIST_DIR=./vector_db
